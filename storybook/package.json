{
  "name": "azion-console-kit-storybook",
  "private": false,
  "description": "Storybook documentation for azion-console-kit templates",
  "type": "module",
  "scripts": {
    "build": "storybook build -o dist -c .storybook",
    "build:azion": "azion build --debug",
    "dev": "storybook dev -p 6006 -c .storybook",
    "preview": "npx http-server dist -p 6007",
    "deploy": "azion deploy --local --debug"
  }
}
